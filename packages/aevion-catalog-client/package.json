{
  "name": "@aevion/catalog-client",
  "version": "0.6.0",
  "description": "TypeScript client for the AEVION Hub catalog API (/api/aevion/*) — module discovery, registry stats, status badges. Zero deps.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "vitest",
    "test:run": "vitest run",
    "dry-publish": "npm publish --dry-run --access public",
    "verify-package": "npm pack --dry-run 2>&1 | tail -20 && echo '--- size estimate ---' && du -sh dist 2>/dev/null || true"
  },
  "keywords": [
    "aevion",
    "catalog",
    "module-registry",
    "discovery",
    "typescript",
    "sdk"
  ],
  "author": "AEVION",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dossymbek281078/AEVION.git",
    "directory": "packages/aevion-catalog-client"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}

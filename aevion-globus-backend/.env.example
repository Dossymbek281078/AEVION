# Copy to .env and adjust.

DATABASE_URL=postgresql://postgres:password@localhost:5432/aevion_dev

AUTH_JWT_SECRET=change-me-in-production
AUTH_JWT_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# QCoreAI — multi-agent LLM pipeline. At least one provider key required for
# real /multi-agent runs (otherwise stub text). Recommended: ANTHROPIC + OPENAI
# so per-role overrides have headroom.
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
GROK_API_KEY=

# QCoreAI hard cap (USD). Per-run requested budget can't exceed this.
# Default 50.
QCORE_MAX_COST_USD_PER_RUN=50

# QCoreAI webhook fan-out (env-level fallback when user has no personal hook).
# Optional. When set, run.completed events POST to this URL signed with
# QCORE_WEBHOOK_SECRET via X-QCore-Signature header.
QCORE_WEBHOOK_URL=
QCORE_WEBHOOK_SECRET=

# V6-R: optional Redis pub/sub for mid-run guidance bus. Set this on every
# backend instance + run `npm i ioredis` to enable horizontal scaling.
# Without this, behavior is the in-process Map (default, single-instance OK).
QCORE_REDIS_URL=

# -----------------------------------------------------------------------------
# Quantum Shield — HMAC secret for authenticated Shamir shards.
# REQUIRED. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Must be 32 bytes (base64-encoded). Rotation: add SHARD_HMAC_SECRET_V2 and bump
# HMAC_KEY_VERSION in src/config/qright.ts (not in scope for v2 Tier 1).
# -----------------------------------------------------------------------------
SHARD_HMAC_SECRET=

# -----------------------------------------------------------------------------
# QSign v1 / pipeline HMAC secret (legacy; used by pipeline.ts and
# planetCompliance.ts, also by GET /api/pipeline/verify/:id). REQUIRED (>=16 chars).
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Rotating this value invalidates HMAC re-verification for all existing
# IPCertificate rows — do not rotate casually.
# -----------------------------------------------------------------------------
QSIGN_SECRET=

# -----------------------------------------------------------------------------
# QSign v2 (new /api/qsign/v2/* endpoints)
# Kid-scoped keys. Referenced from the QSignKey table by env var name.
# In production these MUST be set; dev falls back to ephemeral material.
# -----------------------------------------------------------------------------
# HMAC-SHA256 active key (min 16 chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
QSIGN_HMAC_V1_SECRET=

# Ed25519 active key - 64-char hex = raw 32-byte seed. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
QSIGN_ED25519_V1_PRIVATE=
# Optional - if set, must be 64-char hex and match the public key derived from V1_PRIVATE.
# If omitted, backend derives and caches on first boot.
QSIGN_ED25519_V1_PUBLIC=

# -----------------------------------------------------------------------------
# AEV wallet/ledger storage
# -----------------------------------------------------------------------------
# Where jsonFileStore writes wallet/ledger snapshots (relative to cwd if
# omitted → ./.aevion-data). Override для Docker/прода персистентного volume.
AEVION_DATA_DIR=

# -----------------------------------------------------------------------------
# Demo / dev-only
# -----------------------------------------------------------------------------
# Enable stateless demo endpoints for the /reconstruct-demo UI.
# DO NOT enable in production unless you want the endpoints publicly reachable.
# Default: false. In-memory rate-limit 10 req/min/IP applies when enabled.
ENABLE_DEMO_ENDPOINTS=false

# -----------------------------------------------------------------------------
# QBuild — payment webhook & AI surfaces
# -----------------------------------------------------------------------------
# Webhook HMAC secret for POST /api/build/webhooks/payment.
# If unset, the webhook only accepts requests from localhost (dev mode).
# In production MUST be set; Stripe/YooKassa sign payloads with this secret.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BUILD_PAYMENT_WEBHOOK_SECRET=

# Anthropic key for QBuild AI surfaces:
#   POST /api/build/ai/consult       — career coach chat
#   POST /api/build/ai/parse-resume  — resume parser (text + image)
#   POST /api/build/ai/improve-text  — rewrite snippets
# Without this key all three endpoints return a 500 with "ANTHROPIC_API_KEY not configured".
# Rate-limited to 10 calls per 10 minutes per user.
ANTHROPIC_API_KEY=

# Resend API key for email notifications (job alerts, application accept/reject, verification):
#   https://resend.com — free tier: 3000 emails/month
#   If unset, email notifications are silently skipped (platform still works)
RESEND_API_KEY=

# Optional: URL of your employer's webhook endpoint for new application events
#   POST with JSON { event: "application.new", applicationId, vacancyId, ... }
#   Signed with BUILD_PAYMENT_WEBHOOK_SECRET (X-Aevion-Signature header)
BUILD_APPLICATION_WEBHOOK_URL=

# Canonical site URL for sitemap.ts (Next.js). Set in Vercel env.
NEXT_PUBLIC_SITE_URL=https://aevion.tech

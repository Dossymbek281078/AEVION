# QBuild product source dirs (collide with the broad **/build/ rule above —
# these are TS/TSX modules under our own src tree, not output artifacts).
!aevion-globus-backend/src/lib/build/
!aevion-globus-backend/src/lib/build/**
!frontend/src/lib/build/
!frontend/src/lib/build/**
!frontend/src/components/build/
!frontend/src/components/build/**
!frontend/src/app/build/
!frontend/src/app/build/**

# Environment variables - NEVER commit secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
**/.env
**/.env.local
**/.env.*.local


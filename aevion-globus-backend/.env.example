# Copy to .env and adjust.

DATABASE_URL=postgresql://postgres:password@localhost:5432/aevion_dev

AUTH_JWT_SECRET=change-me-in-production
AUTH_JWT_EXPIRES_IN=7d

# ─────────────────────────────────────────────────────────────────────────────
# QCoreAI multi-agent — provider keys.
# At least ONE provider key must be set for /api/qcoreai/chat and the
# multi-agent pipeline to do real work. Without any key, /chat returns stub
# text and /multi-agent emits an "error" SSE event explaining the missing key.
# ─────────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
GROK_API_KEY=

# QCoreAI — operational guardrails.
# Hard cost cap (USD) applied across the whole multi-agent run. After every
# agent finishes, the running USD total is compared to this number and the
# pipeline is halted with status="capped" if exceeded. Per-request body
# field `costCapUsd` overrides this default. Leave unset for no global cap.
QCORE_HARD_CAP_USD=

# QCoreAI — outbound webhook on run.completed (Zapier/Make/internal tools).
# Without QCORE_WEBHOOK_URL the feature is silently disabled. With a URL
# present, every finished run (done/stopped/error/capped) POSTs a JSON
# payload. Set QCORE_WEBHOOK_SECRET to enable HMAC-SHA256 signing
# (X-QCore-Signature: sha256=<hex>) so receivers can verify integrity.
QCORE_WEBHOOK_URL=
QCORE_WEBHOOK_SECRET=

# Quantum Shield — HMAC secret for authenticated Shamir shards.
# REQUIRED. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Must be 32 bytes (base64-encoded). Rotation: add SHARD_HMAC_SECRET_V2 and bump
# HMAC_KEY_VERSION in src/config/qright.ts (not in scope for v2 Tier 1).
SHARD_HMAC_SECRET=

# QSign HMAC secret (separate from SHARD_HMAC_SECRET). REQUIRED (>=16 chars).
# Used to re-verify certificate HMAC signatures in GET /api/pipeline/verify/:id.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Rotating this value invalidates HMAC re-verification for all existing
# IPCertificate rows — do not rotate casually.
QSIGN_SECRET=

# Enable stateless demo endpoints for the /reconstruct-demo UI.
# DO NOT enable in production unless you want the endpoints publicly reachable.
# Default: false. In-memory rate-limit 10 req/min/IP applies when enabled.
ENABLE_DEMO_ENDPOINTS=false

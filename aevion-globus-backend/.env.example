# Copy to .env and adjust.

DATABASE_URL=postgresql://postgres:password@localhost:5432/aevion_dev

AUTH_JWT_SECRET=change-me-in-production
AUTH_JWT_EXPIRES_IN=7d

# QCoreAI - optional; without key, /api/qcoreai/chat returns stub text
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# -----------------------------------------------------------------------------
# QSign v1 (legacy; still used by pipeline.ts and planetCompliance.ts)
# -----------------------------------------------------------------------------
QSIGN_SECRET=aevion-hmac-secret-2026

# -----------------------------------------------------------------------------
# QSign v2 (new /api/qsign/v2/* endpoints)
# Kid-scoped keys. Referenced from the QSignKey table by env var name.
# In production these MUST be set; dev falls back to ephemeral material.
# -----------------------------------------------------------------------------
# HMAC-SHA256 active key (min 16 chars)
QSIGN_HMAC_V1_SECRET=

# Ed25519 active key - 64-char hex = raw 32-byte seed.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
QSIGN_ED25519_V1_PRIVATE=
# Optional - if set, must be 64-char hex and match the public key derived from V1_PRIVATE.
# If omitted, backend derives and caches on first boot.
QSIGN_ED25519_V1_PUBLIC=

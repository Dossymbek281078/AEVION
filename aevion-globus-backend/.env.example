# Copy to .env and adjust.

DATABASE_URL=postgresql://postgres:password@localhost:5432/aevion_dev

AUTH_JWT_SECRET=change-me-in-production
AUTH_JWT_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# QCoreAI — multi-agent LLM pipeline. At least one provider key required for
# real /multi-agent runs (otherwise stub text). Recommended: ANTHROPIC + OPENAI
# so per-role overrides have headroom.
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
GROK_API_KEY=

# QCoreAI hard cap (USD). Per-run requested budget can't exceed this.
# Default 50.
QCORE_MAX_COST_USD_PER_RUN=50

# QCoreAI webhook fan-out (env-level fallback when user has no personal hook).
# Optional. When set, run.completed events POST to this URL signed with
# QCORE_WEBHOOK_SECRET via X-QCore-Signature header.
QCORE_WEBHOOK_URL=
QCORE_WEBHOOK_SECRET=

# V6-R: optional Redis pub/sub for mid-run guidance bus. Set this on every
# backend instance + run `npm i ioredis` to enable horizontal scaling.
# Without this, behavior is the in-process Map (default, single-instance OK).
QCORE_REDIS_URL=

# -----------------------------------------------------------------------------
# Quantum Shield — HMAC secret for authenticated Shamir shards.
# REQUIRED. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Must be 32 bytes (base64-encoded). Rotation: add SHARD_HMAC_SECRET_V2 and bump
# HMAC_KEY_VERSION in src/config/qright.ts (not in scope for v2 Tier 1).
# -----------------------------------------------------------------------------
SHARD_HMAC_SECRET=

# -----------------------------------------------------------------------------
# QSign v1 / pipeline HMAC secret (legacy; used by pipeline.ts and
# planetCompliance.ts, also by GET /api/pipeline/verify/:id). REQUIRED (>=16 chars).
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Rotating this value invalidates HMAC re-verification for all existing
# IPCertificate rows — do not rotate casually.
# -----------------------------------------------------------------------------
QSIGN_SECRET=

# -----------------------------------------------------------------------------
# QSign v2 (new /api/qsign/v2/* endpoints)
# Kid-scoped keys. Referenced from the QSignKey table by env var name.
# In production these MUST be set; dev falls back to ephemeral material.
# -----------------------------------------------------------------------------
# HMAC-SHA256 active key (min 16 chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
QSIGN_HMAC_V1_SECRET=

# Ed25519 active key - 64-char hex = raw 32-byte seed. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
QSIGN_ED25519_V1_PRIVATE=
# Optional - if set, must be 64-char hex and match the public key derived from V1_PRIVATE.
# If omitted, backend derives and caches on first boot.
QSIGN_ED25519_V1_PUBLIC=

# -----------------------------------------------------------------------------
# AEV wallet/ledger storage
# -----------------------------------------------------------------------------
# Where jsonFileStore writes wallet/ledger snapshots (relative to cwd if
# omitted → ./.aevion-data). Override для Docker/прода персистентного volume.
AEVION_DATA_DIR=

# -----------------------------------------------------------------------------
# Demo / dev-only
# -----------------------------------------------------------------------------
# Enable stateless demo endpoints for the /reconstruct-demo UI.
# DO NOT enable in production unless you want the endpoints publicly reachable.
# Default: false. In-memory rate-limit 10 req/min/IP applies when enabled.
ENABLE_DEMO_ENDPOINTS=false

# -----------------------------------------------------------------------------
# QBuild — payment webhook & AI surfaces
# -----------------------------------------------------------------------------
# Webhook HMAC secret for POST /api/build/webhooks/payment.
# If unset, the webhook only accepts requests from localhost (dev mode).
# In production MUST be set; Stripe/YooKassa sign payloads with this secret.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BUILD_PAYMENT_WEBHOOK_SECRET=

# Anthropic key for QBuild AI surfaces:
#   POST /api/build/ai/consult       — career coach chat
#   POST /api/build/ai/parse-resume  — resume parser (text + image)
#   POST /api/build/ai/improve-text  — rewrite snippets
# Without this key all three endpoints return a 500 with "ANTHROPIC_API_KEY not configured".
# Rate-limited to 10 calls per 10 minutes per user.
ANTHROPIC_API_KEY=

# Daily.co API key for video rooms (QBuild v2 killer feature #9).
# Without this key, POST /api/build/video/rooms returns stub URL
# https://aevion.daily.co/<roomName> (works in dev, opens Daily.co landing).
# Get a free key at https://dashboard.daily.co/
DAILY_API_KEY=

# Web Push (QBuild v3): VAPID keys for browser push notifications.
# Generate with: npx web-push generate-vapid-keys
# Without these, /api/build/push/* returns gracefully but no notifications fire.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:noreply@aevion.io

# -----------------------------------------------------------------------------
# Email notifications (QBuild transactional email via SMTP)
# Without these, all emails are silently skipped — no errors thrown.
# Gmail: SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  (use App Password, not real pass)
# Yandex: SMTP_HOST=smtp.yandex.ru  SMTP_PORT=587
# Mailgun: SMTP_HOST=smtp.mailgun.org  SMTP_PORT=587
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="AEVION QBuild <noreply@aevion.io>"

# -----------------------------------------------------------------------------
# Stripe payments for QBuild hire fees + subscriptions.
# Without STRIPE_SECRET_KEY the checkout endpoint falls back to dev-mode
# (immediate PAID flip, no real charge).
# Get keys: https://dashboard.stripe.com/apikeys
# Webhook secret: https://dashboard.stripe.com/webhooks
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
FRONTEND_URL=https://aevion.app

# -----------------------------------------------------------------------------
# Smeta Trainer — LMS integration
# Optional. When set, POST /api/smeta-trainer/lms/lesson-complete requires
# the X-Webhook-Secret header to match. Without this, the endpoint is open.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# -----------------------------------------------------------------------------
SMETA_LMS_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# QPayNet — embedded payment infrastructure
# QPAYNET_DAILY_DEPOSIT_CAP: max deposit per wallet per day (KZT). Default: 500000
# QPAYNET_MAX_TRANSFER: max single transfer amount (KZT). Default: 100000
# -----------------------------------------------------------------------------
QPAYNET_DAILY_DEPOSIT_CAP=500000
QPAYNET_MAX_TRANSFER=100000

# KYC: monthly outgoing threshold before verification required.
# QPAYNET_KYC_AUTO_VERIFY=1 in dev/staging skips manual review.
QPAYNET_KYC_THRESHOLD=1000000
QPAYNET_KYC_AUTO_VERIFY=0

# Stripe deposit gateway. With STRIPE_SECRET_KEY set + webhook secret,
# /deposit/checkout creates real Stripe Checkout Sessions in KZT.
# Without — falls back to stub flow (POST /deposit/confirm-stub).
# Webhook URL: POST {BACKEND}/api/qpaynet/deposit/webhook
QPAYNET_STRIPE_WEBHOOK_SECRET=

# Payouts: comma-separated emails who can /admin/payouts/:id/{approve,mark-paid,reject}
QPAYNET_ADMIN_EMAILS=

# Application-layer at-rest encryption for webhook notify_secret.
# Accepts: 64-char hex (raw 32 bytes) OR any other string (passphrase mode,
# hashed via SHA-256 to 32 bytes).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Without this, secrets are stored as plaintext (back-compat OK; rotate to
# encrypted by re-issuing affected requests).
# Loss = inability to decrypt existing rows; rotation = decrypt+re-encrypt
# job (not yet implemented; for now only single key).
QPAYNET_ENCRYPTION_KEY=

# DB pool tuning (defaults are sane; only override under load):
PG_POOL_MAX=20
PG_POOL_IDLE_MS=30000
PG_POOL_CONN_MS=5000
PG_STATEMENT_TIMEOUT_MS=10000

# -----------------------------------------------------------------------------
# QContract — self-destruct smart documents
# No required env vars. Uses shared DATABASE_URL and FRONTEND_URL.
# Optional: QCONTRACT_MAX_CONTENT_BYTES (default 100000 = 100kb)
# -----------------------------------------------------------------------------
QCONTRACT_MAX_CONTENT_BYTES=100000

# Copy to .env and adjust.

DATABASE_URL=postgresql://postgres:password@localhost:5432/aevion_dev

AUTH_JWT_SECRET=change-me-in-production
AUTH_JWT_EXPIRES_IN=7d

# QCoreAI — optional; without key, /api/qcoreai/chat returns stub text
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Quantum Shield — HMAC secret for authenticated Shamir shards.
# REQUIRED. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Must be 32 bytes (base64-encoded). Rotation: add SHARD_HMAC_SECRET_V2 and bump
# HMAC_KEY_VERSION in src/config/qright.ts (not in scope for v2 Tier 1).
SHARD_HMAC_SECRET=

# QSign HMAC secret (separate from SHARD_HMAC_SECRET). Generate with the
# same command above. Falls back to "dev-qsign-secret" in dev only.
QSIGN_SECRET=

# Enable stateless demo endpoints for the /reconstruct-demo UI.
# DO NOT enable in production unless you want the endpoints publicly reachable.
# Default: false. In-memory rate-limit 10 req/min/IP applies when enabled.
ENABLE_DEMO_ENDPOINTS=false

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model QRightObject {
  id           String   @id @default(uuid())
  title        String
  description  String
  kind         String
  contentHash  String
  ownerName    String?
  ownerEmail   String?
  ownerUserId  String?
  country      String?
  city         String?
  createdAt    DateTime @default(now())
}
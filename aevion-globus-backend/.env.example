# Copy to .env and adjust.

DATABASE_URL=postgresql://postgres:password@localhost:5432/aevion_dev

AUTH_JWT_SECRET=change-me-in-production
AUTH_JWT_EXPIRES_IN=7d

# QCoreAI — optional; without key, /api/qcoreai/chat returns stub text
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Pricing / Stripe Checkout — optional.
# Без STRIPE_SECRET_KEY эндпоинт /api/pricing/checkout/session работает в STUB-режиме:
# возвращает success-URL без реальной оплаты — UX-flow прокликивается полностью.
# Для production: получите ключи на https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Webhook secret из stripe dashboard → Developers → Webhooks → endpoint
# Если не задан — webhook принимает любой запрос как stub (для smoke-тестов)
STRIPE_WEBHOOK_SECRET=
# URL фронтенда для success/cancel редиректов из Stripe
FRONTEND_URL=http://localhost:3000

# Pricing leads (заявки от Enterprise / индустрий)
# По умолчанию: ./data/leads.jsonl (gitignored)
# LEADS_FILE=/var/log/aevion/leads.jsonl

# Analytics events (page_view, cta_click, checkout_start, etc)
# По умолчанию: ./data/events.jsonl (gitignored)
# EVENTS_FILE=/var/log/aevion/events.jsonl

# Admin token для /pricing/admin (просмотр лидов и метрик).
# Без него endpoints /api/pricing/leads, /events/summary, /events/recent
# отдают 401. Сгенерируйте: `openssl rand -hex 32` или равноценно.
ADMIN_TOKEN=

# ───────────────────────────────────────────────────────────────────
# AEVION frontend-exchange · environment variables example
# Copy to .env.local (gitignored) before `npm run dev` / `npm run build`.
# ───────────────────────────────────────────────────────────────────

# ── Backend proxy ────────────────────────────────────────────────
# Browser hits same-origin /api-backend/* and Next rewrites to this URL.
BACKEND_PROXY_TARGET=http://127.0.0.1:4001

# ── AEV wallet/ledger backend (opt-in) ───────────────────────────
# Когда задан → frontend syncит wallet/ledger в backend (см. src/lib/aevApi.ts).
# Без env-var → wallet остаётся pure-localStorage (current behaviour).
NEXT_PUBLIC_AEV_BACKEND_URL=

# ── Telemetry sinks (optional forward seams) ─────────────────────
# When set, /api/metrics POST is forwarded to this URL (Web Vitals).
METRICS_FORWARD_URL=
# When set, /api/errors POST is forwarded to this URL (client errors).
ERRORS_FORWARD_URL=

# ── Sentry (skip-if-no-DSN guards in sentry.{client,server,edge}.config.ts) ──
# Both empty → SDK НЕ инициализируется, /api/errors остаётся единственным sink.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENV=
SENTRY_ENV=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_TRACES_SAMPLE_RATE=0.05
# Source-map upload (опц.) — для Sentry CLI; используется withSentryConfig.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ── Versioning (отображается в /api/health → version) ────────────
# CI/CD set this to commit SHA or release tag; default is "dev".
NEXT_PUBLIC_APP_VERSION=dev

# ── Bundle analyzer (npm run analyze) ────────────────────────────
ANALYZE=

# ── AEV wallet/ledger backend (opt-in) ───────────────────────────
# Когда задан → frontend syncит wallet/ledger в backend (см. src/lib/aevApi.ts).
# Без env-var → wallet остаётся pure-localStorage (default behaviour).
# Backend endpoints: aevion-globus-backend src/routes/aev.ts
NEXT_PUBLIC_AEV_BACKEND_URL=

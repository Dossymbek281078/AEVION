# =============================================================================
# AEVION Payments Rail — environment variables
# Copy to `.env.local` for local dev or wire via Vercel dashboard for prod.
# =============================================================================

# ─── Persistence (Upstash Redis REST — used by Vercel KV and Upstash) ────────
# When EITHER pair is set, /api/payments/v1/* routes persist to Redis so
# refunds, audit log, and idempotency cache survive serverless cold starts.
# Otherwise the rail falls back to in-process globalThis Maps (demo mode).
#
# To provision in production: Vercel dashboard → Storage → Create Database →
# Upstash → Redis → Connect to Project. Env vars are auto-injected.

# Vercel KV variant:
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Upstash marketplace variant (auto-injected by the Upstash Vercel integration):
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Email receipts via Resend ───────────────────────────────────────────────
# When RESEND_API_KEY is set, paid checkouts that include payer_email will
# fire a receipt email via api.resend.com/emails. RESEND_FROM is optional;
# defaults to "AEVION Payments <receipts@aevion.app>".
RESEND_API_KEY=
RESEND_FROM=

# ─── Stripe-style webhook signing override (optional) ────────────────────────
# Per-endpoint secrets are auto-generated (whsec_…). This is only used for
# tests that need a deterministic signature.
# AEVION_WEBHOOK_SIGNING_SECRET=

# =============================================================================
# AEVION Payments Rail — environment variables
# Copy to `.env.local` for local dev or wire via Vercel dashboard for prod.
# =============================================================================

# ─── Persistence (Vercel KV / Upstash Redis REST) ────────────────────────────
# When BOTH are set, /api/payments/v1/* routes persist to KV (refunds, audit
# log, idempotency) so data survives serverless cold starts.
# When unset, the rail falls back to in-process globalThis Maps (demo mode).
#
# To provision in production:
#   Vercel dashboard → Storage → Create Database → KV → Connect to project.
#   Both vars are auto-injected. No code changes.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ─── Email receipts (planned v1.4) ───────────────────────────────────────────
# When set, paid checkouts will trigger a Resend email with the /r/[id] receipt.
# RESEND_API_KEY=

# ─── Stripe-style webhook signing override (optional) ────────────────────────
# Per-endpoint secrets are auto-generated (whsec_…). This is only used for
# tests that need a deterministic signature.
# AEVION_WEBHOOK_SIGNING_SECRET=

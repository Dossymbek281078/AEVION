generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model QRightObject {
  id           String   @id @default(uuid())
  title        String
  description  String
  kind         String
  contentHash  String
  ownerName    String?
  ownerEmail   String?
  ownerUserId  String?
  country      String?
  city         String?
  createdAt    DateTime @default(now())
}
model QuantumShield {
  id          String   @id @default(uuid())
  objectId    String?
  objectTitle String?
  algorithm   String   @default("Shamir's Secret Sharing + Ed25519")
  threshold   Int      @default(2)
  totalShards Int      @default(3)
  shards      String
  signature   String?
  publicKey   String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
}

// ============ HealthAI ============

model HealthProfile {
  id          String   @id
  age         Int      @default(0)
  sex         String   @default("other")
  heightCm    Int      @default(0)
  weightKg    Float    @default(0)
  conditions  String[] @default([])
  allergies   String[] @default([])
  medications String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  symptomChecks SymptomCheck[]
  dailyLogs     HealthDailyLog[]
}

model SymptomCheck {
  id         String   @id
  profileId  String
  symptoms   String[] @default([])
  severity   Int      @default(5)
  durationH  Float    @default(0)
  notes      String?
  matched    Json     @default("[]")
  generic    String?
  disclaimer String?
  createdAt  DateTime @default(now())

  profile HealthProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, createdAt])
}

model HealthDailyLog {
  id          String   @id
  profileId   String
  date        String
  sleepHours  Float?
  moodScore   Int?
  weightKg    Float?
  waterL      Float?
  exerciseMin Int?
  notes       String?
  createdAt   DateTime @default(now())

  profile HealthProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, date])
  @@index([profileId, date])
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model QRightObject {
  id           String   @id @default(uuid())
  title        String
  description  String
  kind         String
  contentHash  String
  ownerName    String?
  ownerEmail   String?
  ownerUserId  String?
  country      String?
  city         String?
  createdAt    DateTime @default(now())
}

model QuantumShield {
  id             String   @id @default(uuid())
  objectId       String?
  objectTitle    String?
  algorithm      String   @default("Shamir's Secret Sharing + Ed25519")
  threshold      Int      @default(2)
  totalShards    Int      @default(3)
  shards         String
  signature      String?
  publicKey      String?
  status         String   @default("active")
  legacy         Boolean  @default(false)
  hmacKeyVersion Int      @default(1) @map("hmac_key_version")
  createdAt      DateTime @default(now())
}

{
  "name": "@aevion-io/catalog-client",
  "version": "0.8.0",
  "description": "TypeScript client for the AEVION Hub catalog API (/api/aevion/*) — module discovery, registry stats, status badges, plus typed sub-clients for QStore, QLearn, QEvents, DevHub, Planet, QCoreAI, Multichat, QMedia, Coach. Zero deps.",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build && npm run test:run",
    "test": "vitest",
    "test:run": "vitest run",
    "dry-publish": "npm publish --dry-run --access public",
    "verify-package": "npm pack --dry-run 2>&1 | tail -20 && echo '--- size estimate ---' && du -sh dist 2>/dev/null || true"
  },
  "keywords": [
    "aevion",
    "catalog",
    "module-registry",
    "discovery",
    "typescript",
    "sdk",
    "qstore",
    "qlearn",
    "qevents",
    "devhub",
    "qcoreai",
    "multichat",
    "qmedia",
    "coach",
    "planet",
    "client",
    "api-client",
    "zero-deps"
  ],
  "author": "AEVION <hello@aevion.app>",
  "license": "MIT",
  "homepage": "https://github.com/Dossymbek281078/AEVION/tree/main/packages/aevion-catalog-client#readme",
  "bugs": {
    "url": "https://github.com/Dossymbek281078/AEVION/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dossymbek281078/AEVION.git",
    "directory": "packages/aevion-catalog-client"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
